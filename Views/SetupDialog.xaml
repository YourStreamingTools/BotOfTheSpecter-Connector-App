<Window x:Class="BotOfTheSpecterOBSConnector.Views.SetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BotOfTheSpecter OBS Connector - Setup"
        Width="500" Height="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#2b2b2b">
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,5,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3c3c3c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#3c3c3c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4a90e2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Welcome to BotOfTheSpecter OBS Connector" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Please configure your settings to get started:" Foreground="LightGray" HorizontalAlignment="Center"/>
        </StackPanel>
        <!-- Settings Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- API Configuration -->
                <TextBlock Text="API Configuration" FontSize="14" FontWeight="Bold" Foreground="#4a90e2" Margin="0,0,0,10"/>
                <Label Content="API Key *"/>
                <TextBox Name="ApiKeyTextBox" ToolTip="Your BotOfTheSpecter API key (required)"/>
                <Button Name="ValidateApiButton" Content="Validate API Key" 
                        Click="ValidateApiButton_Click" 
                        HorizontalAlignment="Left" Width="150" Margin="0,0,0,20"/>
                <!-- OBS Configuration -->
                <TextBlock Text="OBS WebSocket Configuration" FontSize="14" FontWeight="Bold" Foreground="#4a90e2" Margin="0,10,0,10"/>
                <Label Content="Server IP"/>
                <TextBox Name="ServerIpTextBox" Text="localhost" ToolTip="OBS WebSocket server IP (usually localhost)"/>
                <Label Content="Server Port"/>
                <TextBox Name="ServerPortTextBox" Text="4455" ToolTip="OBS WebSocket server port (default: 4455)"/>
                <Label Content="Server Password"/>
                <PasswordBox Name="ServerPasswordBox" ToolTip="OBS WebSocket server password (if configured)"/>
                <Button Name="TestOBSButton" Content="Test OBS Connection" 
                        Click="TestOBSButton_Click" 
                        HorizontalAlignment="Left" Width="150" Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>
        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Name="SkipButton" Content="Skip Setup" Click="SkipButton_Click" Background="Gray"/>
            <Button Name="SaveButton" Content="Save &amp; Continue" Click="SaveButton_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
